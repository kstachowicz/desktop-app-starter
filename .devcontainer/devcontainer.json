{
  "name": "PJATK Electron Dev",
  "build": {
    "dockerfile": "Dockerfile"
  },

  "features": {
    "ghcr.io/devcontainers/features/desktop-lite:1": {
      "password": "vscode",
      "webPort": "6080",
      "vncPort": "5901"
    }
  },

  "postCreateCommand": "npm install",
  "postAttachCommand": "nohup bash -c 'sleep 5 && npm start' > /tmp/electron.log 2>&1 &",

  "forwardPorts": [6080],
  "portsAttributes": {
    "6080": {
      "label": "Desktop — open this to see the app",
      "onAutoForward": "openBrowser"
    },
    "5901": { "onAutoForward": "ignore" }
  },

  "customizations": {
    "vscode": {
      "extensions": [
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode"
      ],
      "settings": {
        "typescript.tsdk": "node_modules/typescript/lib"
      }
    }
  },

  "remoteUser": "node"
}
